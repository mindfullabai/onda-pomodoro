{
  "id": "example.git-status-banner",
  "name": "Git Status Banner",
  "version": "1.0.0",
  "description": "Adds a status bar item showing the current branch and dirty/clean state of the active terminal's cwd.",
  "author": { "name": "Onda Plugin Template" },
  "main": "main.js",
  "capabilities": ["statusbar", "exec", "commands", "notifications"],
  "execPatterns": ["^git "],
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      { "id": "example.git-status-banner.refresh", "title": "Git Banner: Refresh", "category": "Git" }
    ]
  }
}
